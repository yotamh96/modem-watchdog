#!/usr/bin/make -f
# B-04: SOURCE_DATE_EPOCH for reproducibility.
export SOURCE_DATE_EPOCH := $(shell git log -1 --format=%ct 2>/dev/null || date -u +%s)

# B-02: pinned python-build-standalone tarball.
# The exact tarball name lives in debian/python.sha256; we extract it from there
# so a single edit (e.g. CPython security update) doesn't require touching debian/rules.
PYTHON_TARBALL := $(shell awk '{print $$2}' debian/python.sha256)
# Tag is the date component after the '+' in the filename
# e.g. cpython-3.12.13+20260504-aarch64-... -> tag = 20260504
PYTHON_TAG := $(shell awk '{print $$2}' debian/python.sha256 | sed -n 's/^cpython-[0-9.]*+\([0-9]*\)-aarch64.*/\1/p')
PYTHON_URL := https://github.com/astral-sh/python-build-standalone/releases/download/$(PYTHON_TAG)/$(PYTHON_TARBALL)

DESTDIR ?= $(CURDIR)/debian/spark-modem-watchdog
PBSTREE := $(CURDIR)/debian/python-build-standalone
VENVDIR := $(DESTDIR)/opt/spark-modem-watchdog/python
PIPCACHE := $(CURDIR)/debian/.pip-cache

%:
	dh $@

# B-02 + step 1: download + verify SHA + unpack.
debian/python-build-standalone/.unpacked: debian/python.sha256
	mkdir -p debian/python-build-standalone
	rm -rf debian/python-build-standalone/python
	if [ ! -f debian/$(PYTHON_TARBALL) ]; then \
		curl -sSLf -o debian/$(PYTHON_TARBALL) "$(PYTHON_URL)"; \
	fi
	cd debian && sha256sum -c python.sha256
	tar -C debian/python-build-standalone -xzf debian/$(PYTHON_TARBALL)
	# python-build-standalone tarballs unpack to ./python/...
	test -x debian/python-build-standalone/python/bin/python3.12
	touch debian/python-build-standalone/.unpacked

# override_dh_auto_build: nothing to compile — our "build artifact" is the
# unpacked PBS tree (handled by the .unpacked target below). The actual
# population of the destdir happens in override_dh_auto_install, AFTER
# dh_prep wipes debian/spark-modem-watchdog/. Doing it earlier would just
# get deleted.
override_dh_auto_build: debian/python-build-standalone/.unpacked

# Skip dh_auto_test — Plan 01's CI workflow runs the test suite separately,
# and the .deb build does not need to re-run pytest (build is reproducibility-focused).
override_dh_auto_test:

# Steps 2-4: install PBS into destdir; install runtime libs locked; compileall.
# PITFALLS §18.3: install AT the destination path (/opt/...), not at the builder
# path, so PBS's relocatable bundles don't bake builder paths into .pyc.
#
# This MUST run in override_dh_auto_install (not override_dh_auto_build):
# dh_prep wipes debian/spark-modem-watchdog/ at the start of the binary stage,
# so anything we put there during dh_auto_build gets deleted before dh_install
# runs. dh_auto_install is the canonical hook that runs AFTER dh_prep.
override_dh_auto_install: debian/python-build-standalone/.unpacked
	# Step 1: copy PBS tree into destdir at FINAL install path.
	mkdir -p $(VENVDIR)
	cp -a debian/python-build-standalone/python/. $(VENVDIR)/

	# Step 2: bootstrap pip and install uv as a build-time tool.
	# uv is installed into the bundled python temporarily; it's uninstalled after
	# use so it doesn't bloat the shipped package (NFR-51).
	mkdir -p $(PIPCACHE)
	$(VENVDIR)/bin/python3.12 -m ensurepip --upgrade
	$(VENVDIR)/bin/python3.12 -m pip install --no-cache-dir 'uv>=0.5,<1'

	# Step 3: install all 10 runtime libs into the bundled python, locked against
	# packaging/requirements.lock. --no-deps prevents resolver expansion;
	# --require-hashes enforces the SHA256 hashes from the lock for NFR-52.
	$(VENVDIR)/bin/python3.12 -m uv pip install \
		--python $(VENVDIR)/bin/python3.12 \
		--no-deps --require-hashes \
		-r packaging/requirements.lock

	# Step 4: warm pyc cache (NFR-13 — daemon reaches steady state ≤60s of process start).
	# SOURCE_DATE_EPOCH is exported above so .pyc files are deterministic.
	$(VENVDIR)/bin/python3.12 -m compileall -q $(VENVDIR)/lib

	# Strip the bundled python's pip/setuptools/wheel + uv to keep .deb size <40 MiB
	# (NFR-51). uv was a build-time tool only; we don't ship it on the box.
	$(VENVDIR)/bin/python3.12 -m pip uninstall -y uv pip setuptools wheel || true

	# Sanity: the install path is the final path. Refuse to ship a .deb where
	# the bundled python's sys.executable points anywhere other than /opt/...
	$(VENVDIR)/bin/python3.12 -c "import sys; assert sys.executable == '$(VENVDIR)/bin/python3.12', sys.executable"

# Disable Python bytecode compilation by debhelper's dh_python — we compileall'd
# against SOURCE_DATE_EPOCH already and don't want dh_python to re-compile and
# de-reproduce.
override_dh_python3:

# python-build-standalone ships pre-built relocatable binaries with their own
# debug info, symbol tables, and bundled glibc dependencies. They are not OUR
# build artifacts — debhelper must not re-process them or it will break PBS's
# self-contained guarantees:
#
#   - dh_dwz: PBS uses .debug_line_str (newer DWARF 5) that focal's dwz can't
#     parse: "Unknown debugging section .debug_line_str". Skip entirely.
#   - dh_strip: PBS is already optimised for distribution; re-stripping risks
#     breaking the extension modules' --strip-debug compatibility.
#   - dh_makeshlibs: we ship libpython3.12.so PRIVATELY for our daemon; it
#     must NOT be advertised in /etc/ld.so.conf.d via shlibs metadata.
#   - dh_shlibdeps: the bundled python's links are resolved against PBS's own
#     interpreter, not the system's. Excluding the bundled tree prevents
#     spurious system-package dependencies leaking into ${shlibs:Depends}.
override_dh_dwz:
override_dh_strip:
override_dh_makeshlibs:
override_dh_shlibdeps:
	dh_shlibdeps --exclude=opt/spark-modem-watchdog/python

# Use xz at level 9 for the .deb data archive. Default gzip puts the .deb
# at ~46 MiB (over NFR-51's 40 MiB ceiling); xz -9 brings the compressed
# python-build-standalone tree + 10 runtime libs comfortably under the
# ceiling. dpkg has supported xz natively since wheezy (2013).
override_dh_builddeb:
	dh_builddeb -- -Zxz -z9
